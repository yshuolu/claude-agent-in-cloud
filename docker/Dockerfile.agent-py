# Build stage: install Python dependencies
FROM python:3.12-alpine AS deps

RUN apk add --no-cache gcc musl-dev

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /build

# Copy workspace config
COPY py/pyproject.toml ./pyproject.toml

# Copy package configs
COPY py/packages/base-agent/pyproject.toml packages/base-agent/pyproject.toml
COPY py/packages/agent-local/pyproject.toml packages/agent-local/pyproject.toml

# Create package source dirs so uv can resolve workspace members
RUN mkdir -p packages/base-agent/src/base_agent && \
    touch packages/base-agent/src/base_agent/__init__.py && \
    mkdir -p packages/agent-local/src/local_agent_runner && \
    touch packages/agent-local/src/local_agent_runner/__init__.py

# Install dependencies
RUN uv sync --no-dev --no-editable

# Copy source code
COPY py/packages/base-agent/src packages/base-agent/src
COPY py/packages/agent-local/src packages/agent-local/src

# Reinstall workspace packages with actual source
RUN uv sync --no-dev --no-editable

# Runtime stage: same Python base so venv paths match
FROM python:3.12-alpine AS runner

# Node.js is required because claude CLI is a Node script
# Chromium for Playwright MCP browser automation
# git for repo operations
RUN apk add --no-cache nodejs npm chromium git bash github-cli && \
    npm install -g @anthropic-ai/claude-code @playwright/mcp

# Non-root user — claude CLI refuses bypassPermissions as root
RUN adduser -D agent

# Agent runtime lives in /home/agent/app, workspace for tasks in /app/workspace
WORKDIR /home/agent/app
RUN mkdir -p /app/workspace && chown agent:agent /app/workspace

# Copy the Python virtual environment
COPY --from=deps /build/.venv /home/agent/app/.venv

# Claude config — trust dialog pre-accepted (Python agent uses its own config)
ENV CLAUDE_CONFIG_DIR=/home/agent/.claude
COPY --chown=agent:agent docker/agent-claude-py.json /home/agent/.claude/.claude.json

# MCP config — URL-based, connects to server's /mcp endpoint
COPY --chown=agent:agent docker/agent-mcp-py.json /app/workspace/.mcp.json

# Skills
COPY --chown=agent:agent skills/ /home/agent/.claude/skills/

# Ensure venv is on PATH
ENV PATH="/home/agent/app/.venv/bin:$PATH"

# Playwright uses system Chromium
ENV CHROME_PATH="/usr/bin/chromium-browser"

USER agent

RUN git config --global credential.helper \
    '!f() { echo "username=x-access-token"; echo "password=${GH_TOKEN}"; }; f'

EXPOSE 9100

CMD ["python", "-m", "local_agent_runner.main"]

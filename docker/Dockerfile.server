FROM node:22-alpine AS base
WORKDIR /app

# Install dependencies
FROM base AS deps
COPY ts/package.json ts/package-lock.json* ./
COPY ts/packages/shared/package.json ./packages/shared/
COPY ts/packages/event-store/package.json ./packages/event-store/
COPY ts/packages/memory-service/package.json ./packages/memory-service/
COPY ts/packages/agent-manager/package.json ./packages/agent-manager/
COPY ts/apps/server/package.json ./apps/server/
RUN npm install

# Build
FROM deps AS build
COPY ts/tsconfig.base.json ./
COPY ts/packages/shared/ ./packages/shared/
COPY ts/packages/event-store/ ./packages/event-store/
COPY ts/packages/memory-service/ ./packages/memory-service/
COPY ts/packages/agent-manager/ ./packages/agent-manager/
COPY ts/apps/server/ ./apps/server/
RUN npm run build --workspace=@cloud-agent/shared && \
    npm run build --workspace=@cloud-agent/event-store && \
    npm run build --workspace=@cloud-agent/memory-service && \
    npm run build --workspace=@cloud-agent/agent-manager && \
    npm run build --workspace=@cloud-agent/server

# Run
FROM base AS runner
ENV NODE_ENV=production
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/packages/shared/dist ./packages/shared/dist
COPY --from=build /app/packages/shared/package.json ./packages/shared/
COPY --from=build /app/packages/event-store/dist ./packages/event-store/dist
COPY --from=build /app/packages/event-store/package.json ./packages/event-store/
COPY --from=build /app/packages/memory-service/dist ./packages/memory-service/dist
COPY --from=build /app/packages/memory-service/package.json ./packages/memory-service/
COPY --from=build /app/packages/agent-manager/dist ./packages/agent-manager/dist
COPY --from=build /app/packages/agent-manager/package.json ./packages/agent-manager/
COPY --from=build /app/apps/server/dist ./apps/server/dist
COPY --from=build /app/apps/server/package.json ./apps/server/
COPY --from=build /app/package.json ./

EXPOSE 8000
CMD ["node", "apps/server/dist/index.js"]

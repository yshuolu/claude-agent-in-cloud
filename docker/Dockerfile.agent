# Build stage: install deps + compile TypeScript
FROM node:22-alpine AS deps

WORKDIR /build

# Copy tsconfig base (no lock file — scoped workspace differs from full monorepo)
COPY ts/tsconfig.base.json ./

# Copy only the packages needed by the agent
COPY ts/packages/base-agent/package.json packages/base-agent/package.json
COPY ts/packages/agent-local/package.json packages/agent-local/package.json
COPY ts/packages/project-management/package.json packages/project-management/package.json
COPY ts/mcps/project-management/package.json mcps/project-management/package.json

# Scoped root package.json — only reference workspaces present in the image
# Include claude-agent-sdk at root to ensure hoisting
RUN echo '{"private":true,"workspaces":["packages/*","mcps/*"],"devDependencies":{"typescript":"^5.7.0"},"dependencies":{"@anthropic-ai/claude-agent-sdk":"^0.2.63"}}' > package.json

# Build tools for native addons (cpu-features, etc.)
RUN apk add --no-cache python3 make g++ cmake

# Install dependencies — npm hoists everything to root node_modules
RUN npm install

# Copy source and build
COPY ts/packages/base-agent/src packages/base-agent/src
COPY ts/packages/base-agent/tsconfig.json packages/base-agent/tsconfig.json
COPY ts/packages/agent-local/src packages/agent-local/src
COPY ts/packages/agent-local/tsconfig.json packages/agent-local/tsconfig.json
COPY ts/packages/project-management/src packages/project-management/src
COPY ts/packages/project-management/tsconfig.json packages/project-management/tsconfig.json
COPY ts/mcps/project-management/src mcps/project-management/src
COPY ts/mcps/project-management/tsconfig.json mcps/project-management/tsconfig.json

RUN npx tsc --project packages/base-agent/tsconfig.json && \
    npx tsc --project packages/agent-local/tsconfig.json && \
    npx tsc --project packages/project-management/tsconfig.json && \
    npx tsc --project mcps/project-management/tsconfig.json

# Runtime stage: clean Alpine image
FROM node:22-alpine AS runner

RUN apk add --no-cache git github-cli
RUN mkdir -p /workspace

# Configure git to use GH_TOKEN for HTTPS auth (injected at runtime by agent.ts)
RUN git config --global credential.helper '!f() { echo "username=x-access-token"; echo "password=${GH_TOKEN}"; }; f'

WORKDIR /app

# Copy built output and production deps
COPY --from=deps /build/node_modules ./node_modules
COPY --from=deps /build/packages/base-agent/dist packages/base-agent/dist
COPY --from=deps /build/packages/base-agent/package.json packages/base-agent/package.json
COPY --from=deps /build/packages/agent-local/dist packages/agent-local/dist
COPY --from=deps /build/packages/agent-local/package.json packages/agent-local/package.json
COPY --from=deps /build/packages/project-management/dist packages/project-management/dist
COPY --from=deps /build/packages/project-management/package.json packages/project-management/package.json
COPY --from=deps /build/mcps/project-management/dist mcps/project-management/dist
COPY --from=deps /build/mcps/project-management/package.json mcps/project-management/package.json
COPY --from=deps /build/package.json ./package.json

# MCP servers — .mcp.json at project root, auto-loaded by SDK
COPY docker/agent-mcp.json .mcp.json

# Claude config — trust dialog pre-accepted, .mcp.json servers enabled
ENV CLAUDE_CONFIG_DIR=/root/.claude
COPY docker/agent-claude.json /root/.claude/.claude.json
COPY skills/ /root/.claude/skills/

# System prompt
COPY docker/agent-claude.md CLAUDE.md

EXPOSE 9100

CMD ["node", "packages/agent-local/dist/index.js"]
